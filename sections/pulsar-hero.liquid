<section class="pulsar-hero" aria-label="Hero">
  <div class="pulsar-hero__bg" aria-hidden="true">
    {%- if section.settings.bg_video != blank -%}
      <video
        class="pulsar-hero__bg-video"
        src="{{ section.settings.bg_video }}"
        autoplay muted loop playsinline
        aria-hidden="true"
      ></video>
    {%- else -%}
      {%- comment -%} Fallback: reuse the preloader animation as a looping hero background {%- endcomment -%}
      <video
        class="pulsar-hero__bg-video"
        src="{{ '3d animation for preloader.mp4' | asset_url }}"
        autoplay muted loop playsinline
        aria-hidden="true"
      ></video>
    {%- endif -%}
    <div class="pulsar-hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="pulsar-hero__content">
    <p
      class="pulsar-hero__eyebrow"
      data-pulsar-hero-element
    >{{ section.settings.eyebrow | default: 'EST. 2020 · NORTH AMERICA' }}</p>

    <h1
      class="pulsar-hero__heading"
      data-pulsar-hero-element
    >
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        TEAM<br>PULSAR
      {%- endif -%}
    </h1>

    <p
      class="pulsar-hero__tagline"
      data-pulsar-hero-element
    >{{ section.settings.tagline | default: 'Move With Intent.' }}</p>

    <div class="pulsar-hero__actions" data-pulsar-hero-element>
      <a
        href="{{ section.settings.primary_cta_url | default: '/collections/all' }}"
        class="pulsar-btn pulsar-btn--primary"
      >{{ section.settings.primary_cta_label | default: 'Shop Now' }}</a>
      <a
        href="{{ section.settings.secondary_cta_url | default: '/pages/esports' }}"
        class="pulsar-btn pulsar-btn--ghost"
      >{{ section.settings.secondary_cta_label | default: 'Our Rosters' }}</a>
    </div>
  </div>

  <div class="pulsar-hero__scroll-indicator" data-pulsar-hero-element aria-hidden="true">
    <span class="pulsar-hero__scroll-label">Scroll</span>
    <div class="pulsar-hero__scroll-line"></div>
  </div>
</section>

{% stylesheet %}
  .pulsar-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--pulsar-black);
  }

  /* Background video */
  .pulsar-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .pulsar-hero__bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
  }
  .pulsar-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(10, 10, 12, 0.55) 60%,
      rgba(10, 10, 12, 0.95) 100%
    );
  }

  /* Content */
  .pulsar-hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 var(--pulsar-space-lg);
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pulsar-space-md);
  }

  .pulsar-hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
    margin: 0;
    /* Initial state for GSAP entrance */
    opacity: 0;
  }

  .pulsar-hero__heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(5rem, 16vw, 14rem);
    line-height: 0.88;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
    opacity: 0;
  }

  .pulsar-hero__tagline {
    font-family: var(--font-secondary);
    font-size: clamp(1rem, 2vw, 1.5rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pulsar-gray3);
    margin: 0;
    opacity: 0;
  }

  .pulsar-hero__actions {
    display: flex;
    gap: var(--pulsar-space-md);
    margin-top: var(--pulsar-space-sm);
    opacity: 0;
  }

  /* Scroll indicator */
  .pulsar-hero__scroll-indicator {
    position: absolute;
    bottom: var(--pulsar-space-lg);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pulsar-space-xs);
    z-index: 1;
    opacity: 0;
  }
  .pulsar-hero__scroll-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
  }
  .pulsar-hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--pulsar-gray1), transparent);
    animation: pulsar-scroll-pulse 2s ease-in-out infinite;
  }
  @keyframes pulsar-scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(0.6); }
  }

  /* Responsive */
  @media (max-width: 767px) {
    .pulsar-hero__heading { font-size: clamp(4rem, 20vw, 6rem); }
    .pulsar-hero__actions { flex-direction: column; width: 100%; max-width: 300px; }
    .pulsar-hero__actions .pulsar-btn { text-align: center; justify-content: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pulsar Hero",
  "tag": "div",
  "class": "pulsar-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "EST. 2020 · NORTH AMERICA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TEAM PULSAR"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Move With Intent."
    },
    {
      "type": "url",
      "id": "bg_video",
      "label": "Background video URL (optional — uses preloader animation by default)"
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Button label",
      "default": "Our Rosters"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Pulsar Hero",
      "category": "Pulsar"
    }
  ]
}
{% endschema %}
