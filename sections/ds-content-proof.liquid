{%- liquid
  assign section_heading  = section.settings.heading  | default: 'CULTURE IN MOTION'
  assign section_sublabel = section.settings.sub_label | default: 'CONTENT ECOSYSTEM'
  assign cta_label        = section.settings.cta_label | default: 'VIEW ALL CONTENT →'
  assign cta_url          = section.settings.cta_url   | default: '/pages/content'

  assign creators = shop.metaobjects.dreamstation_creator.values | where: 'is_active', true
  assign creator  = creators | first
-%}

<section
  class="ds-content-proof ds-surface"
  aria-labelledby="ds-content-proof-heading"
>
  <div class="ds-content-proof__inner">

    {%- comment %} ── Section header ── {%- endcomment %}
    <header class="ds-content-proof__header ds-animate-in">
      <p class="ds-content-proof__sublabel" aria-hidden="true">{{ section_sublabel }}</p>
      <span class="sr-only">{{ section_sublabel }}</span>
      <h2 id="ds-content-proof-heading" class="ds-content-proof__heading">
        {{ section_heading }}
      </h2>
    </header>

    {%- comment %} ── X post static fallback tiles ── {%- endcomment %}
    <div class="ds-content-proof__posts" role="list">

      {%- for i in (1..3) -%}
        {%- assign delay_ms = forloop.index0 | times: 100 -%}
        <article
          class="ds-content-proof__post ds-animate-in"
          role="listitem"
          style="transition-delay: {{ delay_ms }}ms"
        >
          <div class="ds-content-proof__post-header">
            {%- comment %} X (Twitter) logo inline SVG {%- endcomment %}
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.743l7.737-8.835L1.254 2.25H8.08l4.253 5.623 5.911-5.623Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"
                fill="currentColor"
              />
            </svg>
            <span class="ds-content-proof__post-handle">@DreamstationGG</span>
          </div>

          <p class="ds-content-proof__post-body">
            Follow @DreamstationGG for match updates, highlights, and org news.
          </p>

          <div class="ds-content-proof__post-footer">
            <a
              href="https://x.com/DreamstationGG"
              class="ds-btn-ghost"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="View Dreamstation on X (Twitter)"
            >VIEW ON X &rarr;</a>
          </div>
        </article>
      {%- endfor -%}

    </div>

    {%- comment %} ── Creator card ── {%- endcomment %}
    {%- if creator != blank -%}
      <div class="ds-content-proof__creator ds-animate-in">

        <div class="ds-content-proof__creator-media">
          {%- if creator.profile_image != blank -%}
            {{
              creator.profile_image
              | image_url: width: 120
              | image_tag:
                alt: creator.display_name,
                class: 'ds-content-proof__creator-img',
                loading: 'lazy'
            }}
          {%- else -%}
            <div
              class="ds-content-proof__creator-initials"
              aria-hidden="true"
            >{{ creator.display_name | slice: 0, 1 }}</div>
          {%- endif -%}
        </div>

        <div class="ds-content-proof__creator-info">
          <h3 class="ds-content-proof__creator-name">{{ creator.display_name }}</h3>

          {%- if creator.platform != blank -%}
            {% render 'ds-performance-chip',
              variant: '',
              label: creator.platform,
              sr_label: creator.platform | append: ' creator'
            %}
          {%- endif -%}

          {%- if creator.subscriber_count != blank -%}
            <p class="ds-content-proof__creator-subs">{{ creator.subscriber_count }}</p>
          {%- endif -%}

          {%- if creator.profile_url != blank -%}
            <a
              href="{{ creator.profile_url }}"
              class="ds-btn-cyan ds-content-proof__creator-cta"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Follow {{ creator.display_name }} on {{ creator.platform }}"
            >FOLLOW &rarr;</a>
          {%- endif -%}
        </div>

      </div>
    {%- else -%}
      {%- comment %} Text fallback — no metaobject data available {%- endcomment %}
      <div class="ds-content-proof__creator ds-content-proof__creator--fallback ds-animate-in">
        <div class="ds-content-proof__creator-media">
          <div class="ds-content-proof__creator-initials" aria-hidden="true">G</div>
        </div>
        <div class="ds-content-proof__creator-info">
          <h3 class="ds-content-proof__creator-name">GROUNDZERO000</h3>
          <p class="ds-content-proof__creator-tagline">Creator. @DreamstationGG &middot; YouTube</p>
          <a
            href="https://www.youtube.com/@GroundZero000"
            class="ds-btn-cyan ds-content-proof__creator-cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow GroundZero000 on YouTube"
          >FOLLOW &rarr;</a>
        </div>
      </div>
    {%- endif -%}

    {%- comment %} ── Section CTA ── {%- endcomment %}
    <div class="ds-content-proof__footer ds-animate-in">
      {% render 'ds-cta-button',
        variant: 'ghost',
        label: cta_label,
        url: cta_url
      %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Content Proof",
  "tag": "section",
  "class": "ds-content-proof-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "CULTURE IN MOTION"
    },
    {
      "type": "text",
      "id": "sub_label",
      "label": "Sub-label",
      "default": "CONTENT ECOSYSTEM"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "VIEW ALL CONTENT →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Content Proof"
    }
  ]
}
{% endschema %}
