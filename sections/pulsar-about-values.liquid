<section class="pulsar-about-values" data-pulsar-section>
  <div class="pulsar-about-values__inner">

    <div class="pulsar-about-values__header">
      <div class="pulsar-about-values__label pulsar-reveal">
        <span class="pulsar-about-values__label-text">WHAT DRIVES US</span>
        <span class="pulsar-about-values__label-line" aria-hidden="true"></span>
      </div>
      <h2 class="pulsar-about-values__heading pulsar-reveal">
        {{ section.settings.heading | default: 'OUR VALUES' }}
      </h2>
      {%- if section.settings.subtext != blank -%}
        <p class="pulsar-about-values__subtext pulsar-reveal">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="pulsar-about-values__grid">
      <article class="pulsar-about-values__card pulsar-reveal">
        <span class="pulsar-about-values__number" aria-hidden="true">01</span>
        <h3 class="pulsar-about-values__title">EXCELLENCE</h3>
        <p class="pulsar-about-values__desc">
          {{ section.settings.value_1_desc | default: "We don't settle. Every player, every piece of content, every decision reflects our commitment to being the best version of ourselves. Excellence is not a destination — it's the standard." }}
        </p>
      </article>

      <article class="pulsar-about-values__card pulsar-reveal">
        <span class="pulsar-about-values__number" aria-hidden="true">02</span>
        <h3 class="pulsar-about-values__title">COMMUNITY</h3>
        <p class="pulsar-about-values__desc">
          {{ section.settings.value_2_desc | default: "Pulsar is more than an org — it's a family. We foster a space where people connect, grow, and share in the wins and losses together. Everyone matters. Everyone is seen." }}
        </p>
      </article>

      <article class="pulsar-about-values__card pulsar-reveal">
        <span class="pulsar-about-values__number" aria-hidden="true">03</span>
        <h3 class="pulsar-about-values__title">INTENT</h3>
        <p class="pulsar-about-values__desc">
          {{ section.settings.value_3_desc | default: "We don't operate on emotion — we move with purpose. Every action, from recruitment to competition, is deliberate, calculated, and aligned with our mission. Intent separates us from the noise." }}
        </p>
      </article>
    </div>

    <div class="pulsar-about-values__divider" aria-hidden="true"></div>

    <p class="pulsar-about-values__tagline pulsar-reveal">
      {{ section.settings.tagline | default: '"EXCELLENCE IS INTENTIONAL."' }}
    </p>

  </div>
</section>

<style>
.pulsar-about-values {
  background: var(--pulsar-dark1);
  padding: var(--pulsar-space-xxl) 0;
}

.pulsar-about-values__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--pulsar-space-lg);
}

/* Header */
.pulsar-about-values__header {
  margin-bottom: var(--pulsar-space-xl);
}

.pulsar-about-values__label {
  display: flex;
  align-items: center;
  gap: var(--pulsar-space-md);
  margin-bottom: var(--pulsar-space-lg);
}

.pulsar-about-values__label-text {
  font: 500 0.75rem/1 var(--font-body);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--pulsar-gray2);
  white-space: nowrap;
}

.pulsar-about-values__label-line {
  flex: 1;
  height: 1px;
  background: var(--pulsar-dark3);
}

.pulsar-about-values__heading {
  font: 900 clamp(2.5rem, 6vw, 5rem)/0.95 var(--font-display);
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: var(--pulsar-white);
  margin: 0 0 var(--pulsar-space-md);
}

.pulsar-about-values__subtext {
  font: 400 1.125rem/1.7 var(--font-body);
  color: var(--pulsar-gray3);
  max-width: 560px;
  margin: 0;
}

/* Cards grid */
.pulsar-about-values__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--pulsar-dark3);
  border: 1px solid var(--pulsar-dark3);
  margin-bottom: var(--pulsar-space-xl);
}

.pulsar-about-values__card {
  position: relative;
  padding: var(--pulsar-space-xl) var(--pulsar-space-lg);
  background: var(--pulsar-dark2);
  transition: background 0.3s ease;
  overflow: hidden;
}

.pulsar-about-values__card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--pulsar-white);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}

.pulsar-about-values__card:hover {
  background: var(--pulsar-dark3);
}

.pulsar-about-values__card:hover::before {
  transform: scaleX(1);
}

.pulsar-about-values__card:focus-within::before {
  transform: scaleX(1);
}

.pulsar-about-values__number {
  display: block;
  font: 700 0.75rem/1 var(--font-body);
  letter-spacing: 0.15em;
  color: var(--pulsar-gray1);
  margin-bottom: var(--pulsar-space-lg);
}

.pulsar-about-values__title {
  font: 900 clamp(1.75rem, 3vw, 2.25rem)/1.0 var(--font-display);
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: var(--pulsar-white);
  margin: 0 0 var(--pulsar-space-md);
}

.pulsar-about-values__desc {
  font: 400 0.9375rem/1.75 var(--font-body);
  color: var(--pulsar-gray3);
  margin: 0;
}

/* Divider */
.pulsar-about-values__divider {
  height: 1px;
  background: var(--pulsar-dark3);
  margin-bottom: var(--pulsar-space-xl);
}

/* Bottom tagline */
.pulsar-about-values__tagline {
  font: 900 clamp(1.5rem, 4vw, 3rem)/1 var(--font-display);
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: var(--pulsar-gray2);
  text-align: center;
  margin: 0;
  font-style: italic;
}

@media (max-width: 767px) {
  .pulsar-about-values__grid {
    grid-template-columns: 1fr;
  }

  .pulsar-about-values__card {
    padding: var(--pulsar-space-lg);
  }
}
</style>

{% schema %}
{
  "name": "About Values",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR VALUES"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext (optional)"
    },
    {
      "type": "textarea",
      "id": "value_1_desc",
      "label": "Excellence description",
      "default": "We don't settle. Every player, every piece of content, every decision reflects our commitment to being the best version of ourselves. Excellence is not a destination — it's the standard."
    },
    {
      "type": "textarea",
      "id": "value_2_desc",
      "label": "Community description",
      "default": "Pulsar is more than an org — it's a family. We foster a space where people connect, grow, and share in the wins and losses together. Everyone matters. Everyone is seen."
    },
    {
      "type": "textarea",
      "id": "value_3_desc",
      "label": "Intent description",
      "default": "We don't operate on emotion — we move with purpose. Every action, from recruitment to competition, is deliberate, calculated, and aligned with our mission. Intent separates us from the noise."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Bottom tagline",
      "default": "\"EXCELLENCE IS INTENTIONAL.\""
    }
  ],
  "presets": [
    { "name": "About Values" }
  ]
}
{% endschema %}
