{%- liquid
  assign all_results = shop.metaobjects.dreamstation_result.values
  assign featured = all_results | where: 'is_featured', true | first
  assign non_featured = all_results | where: 'is_featured', false | sort: 'event_date' | reverse
-%}

<section
  class="ds-results-preview ds-surface"
  aria-labelledby="ds-results-preview-heading"
>
  <div class="ds-results-preview__inner">

    <header class="ds-results-preview__header">
      <h2 id="ds-results-preview-heading" class="ds-results-preview__heading">
        {{ section.settings.heading }}
      </h2>
    </header>

    {%- comment %} ── FEATURED RESULT ── {%- endcomment %}
    <div class="ds-results-preview__featured ds-animate-in">
      {%- if featured != blank -%}
        <div class="ds-results-preview__featured-content">
          <div class="ds-results-preview__placement-wrap">
            <span class="ds-results-preview__placement" aria-hidden="true">{{ featured.placement }}</span>
            <span class="sr-only">Placement: {{ featured.placement }}</span>
          </div>

          <div class="ds-results-preview__featured-body">
            <h3 class="ds-results-preview__event-name">{{ featured.event_name }}</h3>

            <p class="ds-results-preview__meta">
              {{- featured.season -}}
              {%- if featured.season != blank and featured.region != blank %} · {% endif -%}
              {{- featured.region -}}
              {%- if featured.game_title != blank %} · {{ featured.game_title }}{% endif -%}
            </p>

            {%- if featured.prize_usd != blank and featured.prize_usd != 0 -%}
              <p class="ds-results-preview__prize">
                {{ featured.prize_usd | money_without_trailing_zeros }}
              </p>
            {%- endif -%}

            {%- if featured.external_link != blank -%}
              <a
                href="{{ featured.external_link }}"
                class="ds-btn-ghost ds-results-preview__liquipedia-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="View {{ featured.event_name }} on Liquipedia"
              >VIEW ON LIQUIPEDIA &rarr;</a>
            {%- endif -%}
          </div>
        </div>
      {%- else -%}
        <p class="ds-results-preview__no-featured">Results data being configured.</p>
      {%- endif -%}
    </div>

    {%- comment %} ── SUPPORTING RESULTS GRID ── {%- endcomment %}
    {%- assign has_supporting = false -%}
    {%- for result in non_featured limit: 1 -%}
      {%- assign has_supporting = true -%}
    {%- endfor -%}

    {%- if has_supporting -%}
      <div class="ds-results-preview__grid">
        {%- for result in non_featured limit: 3 -%}
          {%- assign card_delay_ms = forloop.index0 | times: 50 -%}
          {%- if result.external_link != blank -%}
            <a
              href="{{ result.external_link }}"
              class="ds-results-preview__card ds-animate-in"
              style="transition-delay: {{ card_delay_ms }}ms;"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ result.event_name }}"
            >
              <div class="ds-results-preview__card-placement" aria-hidden="true">{{ result.placement }}</div>
              <span class="sr-only">Placement: {{ result.placement }}</span>
              <div class="ds-results-preview__card-event">{{ result.event_name }}</div>
              <div class="ds-results-preview__card-meta">
                {{- result.season -}}
                {%- if result.season != blank and result.region != blank %} · {% endif -%}
                {{- result.region -}}
              </div>
            </a>
          {%- else -%}
            <div
              class="ds-results-preview__card ds-animate-in"
              style="transition-delay: {{ card_delay_ms }}ms;"
            >
              <div class="ds-results-preview__card-placement" aria-hidden="true">{{ result.placement }}</div>
              <span class="sr-only">Placement: {{ result.placement }}</span>
              <div class="ds-results-preview__card-event">{{ result.event_name }}</div>
              <div class="ds-results-preview__card-meta">
                {{- result.season -}}
                {%- if result.season != blank and result.region != blank %} · {% endif -%}
                {{- result.region -}}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment %} ── BOTTOM CTA ── {%- endcomment %}
    <div class="ds-results-preview__footer">
      {%- assign results_url = section.settings.cta_url | default: '/pages/results' -%}
      {%- render 'ds-cta-button',
        variant: 'ghost',
        label: section.settings.cta_label,
        url: results_url
      -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Results Preview",
  "tag": "section",
  "class": "ds-results-preview-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "COMPETITIVE RECORD"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "FULL RESULTS \u2192"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Results Preview"
    }
  ]
}
{% endschema %}
