{%- liquid
  assign merch_collection = collections[section.settings.collection]
  if merch_collection == blank
    assign merch_collection = collections.frontpage
  endif
  assign product_limit = section.settings.product_limit | default: 6
-%}

<section class="pulsar-merch">
  <div class="pulsar-merch__inner">

    <div class="pulsar-merch__header">
      <div>
        <p class="pulsar-merch__overline pulsar-reveal">{{ section.settings.overline | default: 'Official Gear' }}</p>
        <h2 class="pulsar-merch__heading pulsar-heading-reveal">
          {{ section.settings.heading | default: 'GEAR UP' }}
        </h2>
      </div>
      <a href="{{ section.settings.shop_url | default: '/collections/all' }}" class="pulsar-btn pulsar-btn--ghost pulsar-reveal">
        {{ section.settings.cta_label | default: 'Shop All' }}
      </a>
    </div>

    <div class="pulsar-merch__grid pulsar-stagger-group">
      {%- if merch_collection.products.size > 0 -%}
        {%- for product in merch_collection.products limit: product_limit -%}
          <div class="pulsar-merch__card pulsar-stagger-item">
            <a href="{{ product.url }}" class="pulsar-merch__card-link" aria-label="{{ product.title }}">
              <div class="pulsar-merch__card-image-wrap">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    class="pulsar-merch__card-image pulsar-merch__card-image--primary"
                    width="600"
                    height="600"
                    loading="lazy"
                  >
                  {%- if product.images[1] != blank -%}
                    <img
                      src="{{ product.images[1] | image_url: width: 600 }}"
                      alt="{{ product.images[1].alt | default: product.title | escape }}"
                      class="pulsar-merch__card-image pulsar-merch__card-image--secondary"
                      width="600"
                      height="600"
                      loading="lazy"
                    >
                  {%- endif -%}
                {%- else -%}
                  <div class="pulsar-merch__card-placeholder" aria-hidden="true">
                    <span>{{ product.title | truncate: 2, '' }}</span>
                  </div>
                {%- endif -%}
                <div class="pulsar-merch__card-overlay" aria-hidden="true">
                  <span class="pulsar-merch__card-view">View Product</span>
                </div>
              </div>
              <div class="pulsar-merch__card-info">
                <h3 class="pulsar-merch__card-title">{{ product.title }}</h3>
                <p class="pulsar-merch__card-price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="pulsar-merch__card-price--sale">{{ product.price | money }}</span>
                    <span class="pulsar-merch__card-price--was">{{ product.compare_at_price | money }}</span>
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </p>
              </div>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholder cards when no collection is set {%- endcomment -%}
        {%- for i in (1..6) -%}
          <div class="pulsar-merch__card pulsar-merch__card--placeholder pulsar-stagger-item">
            <div class="pulsar-merch__card-image-wrap">
              <div class="pulsar-merch__card-placeholder" aria-hidden="true">
                <span>PSR</span>
              </div>
            </div>
            <div class="pulsar-merch__card-info">
              <h3 class="pulsar-merch__card-title">Pulsar Drop {{ i }}</h3>
              <p class="pulsar-merch__card-price">Coming Soon</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="pulsar-merch__footer pulsar-reveal">
      <a href="{{ section.settings.shop_url | default: '/collections/all' }}" class="pulsar-btn pulsar-btn--primary">
        {{ section.settings.cta_label | default: 'Shop All Gear' }}
      </a>
    </div>

  </div>
</section>

{% stylesheet %}
  .pulsar-merch {
    background-color: var(--pulsar-dark1);
    padding: var(--pulsar-space-xxl) 0;
  }
  .pulsar-merch__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--pulsar-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-xl);
  }
  .pulsar-merch__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--pulsar-space-lg);
    flex-wrap: wrap;
  }
  .pulsar-merch__overline {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0 0 var(--pulsar-space-sm);
  }
  .pulsar-merch__heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
  }

  /* Product grid */
  .pulsar-merch__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--pulsar-space-md);
  }

  /* Card */
  .pulsar-merch__card {
    background-color: var(--pulsar-dark2);
    border: 1px solid var(--pulsar-dark3);
    transition:
      transform 0.35s var(--pulsar-ease-out),
      border-color 0.35s ease,
      box-shadow 0.35s var(--pulsar-ease-out);
  }
  .pulsar-merch__card:hover {
    transform: translateY(-6px);
    border-color: var(--pulsar-gray1);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.6);
  }
  .pulsar-merch__card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .pulsar-merch__card-image-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: var(--pulsar-dark3);
  }
  .pulsar-merch__card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--pulsar-ease-out), opacity 0.4s ease;
  }
  .pulsar-merch__card-image--secondary {
    opacity: 0;
  }
  .pulsar-merch__card:hover .pulsar-merch__card-image--primary {
    transform: scale(1.04);
    opacity: 0;
  }
  .pulsar-merch__card:hover .pulsar-merch__card-image--secondary {
    opacity: 1;
    transform: scale(1.04);
  }
  .pulsar-merch__card-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--pulsar-dark3);
  }
  .pulsar-merch__card-placeholder span {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--pulsar-dark1);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }
  .pulsar-merch__card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .pulsar-merch__card:hover .pulsar-merch__card-overlay { opacity: 1; }
  .pulsar-merch__card-view {
    font-family: var(--font-secondary);
    font-size: 0.875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    border: 1px solid rgba(255, 255, 255, 0.6);
    padding: 0.75rem 1.5rem;
  }

  /* Card info */
  .pulsar-merch__card-info {
    padding: var(--pulsar-space-md);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-xs);
  }
  .pulsar-merch__card-title {
    font-family: var(--font-secondary);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
  }
  .pulsar-merch__card-price {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--pulsar-gray2);
    margin: 0;
  }
  .pulsar-merch__card-price--sale { color: var(--pulsar-white); margin-right: 0.5rem; }
  .pulsar-merch__card-price--was {
    text-decoration: line-through;
    color: var(--pulsar-gray1);
    font-size: 0.8rem;
  }

  /* Footer CTA */
  .pulsar-merch__footer { display: flex; justify-content: center; }

  /* Responsive */
  @media (max-width: 1199px) { .pulsar-merch__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 767px) {
    .pulsar-merch { padding: var(--pulsar-space-xl) 0; }
    .pulsar-merch__inner { padding: 0 var(--pulsar-space-md); gap: var(--pulsar-space-lg); }
    .pulsar-merch__grid { grid-template-columns: repeat(2, 1fr); gap: var(--pulsar-space-sm); }
    .pulsar-merch__header { flex-direction: column; align-items: flex-start; }
    .pulsar-merch__header .pulsar-btn { display: none; } /* Hide header CTA on mobile — footer CTA remains */
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pulsar Featured Merch",
  "tag": "div",
  "class": "pulsar-section",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Official Gear"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GEAR UP"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Product collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Shop All Gear"
    },
    {
      "type": "url",
      "id": "shop_url",
      "label": "Shop URL",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Pulsar Featured Merch",
      "category": "Pulsar"
    }
  ]
}
{% endschema %}
