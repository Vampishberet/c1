<button
  class="pulsar-size-guide-trigger"
  type="button"
  aria-haspopup="dialog"
  aria-expanded="false"
  aria-controls="pulsar-size-guide-modal"
>Size Guide</button>

<div
  id="pulsar-size-guide-modal"
  class="pulsar-size-guide"
  role="dialog"
  aria-modal="true"
  aria-label="Size Guide"
  hidden
>
  <div class="pulsar-size-guide__backdrop" data-pulsar-sg-close></div>
  <div class="pulsar-size-guide__panel">
    <div class="pulsar-size-guide__header">
      <p class="pulsar-size-guide__overline">Sizing</p>
      <h2 class="pulsar-size-guide__title">SIZE GUIDE</h2>
      <button
        class="pulsar-size-guide__close"
        type="button"
        aria-label="Close size guide"
        data-pulsar-sg-close
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <line x1="2" y1="2" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="18" y1="2" x2="2" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="pulsar-size-guide__body">
      <p class="pulsar-size-guide__note">All measurements in inches. For a relaxed fit, size up.</p>

      <div class="pulsar-size-guide__table-wrap">
        <table class="pulsar-size-guide__table">
          <thead>
            <tr>
              <th>Size</th>
              <th>Chest</th>
              <th>Length</th>
              <th>Shoulder</th>
              <th>Sleeve</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>XS</td><td>34–36</td><td>27</td><td>16.5</td><td>32</td></tr>
            <tr><td>S</td><td>36–38</td><td>28</td><td>17.5</td><td>33</td></tr>
            <tr><td>M</td><td>38–40</td><td>29</td><td>18.5</td><td>34</td></tr>
            <tr><td>L</td><td>40–42</td><td>30</td><td>19.5</td><td>35</td></tr>
            <tr><td>XL</td><td>42–44</td><td>31</td><td>20.5</td><td>36</td></tr>
            <tr><td>2XL</td><td>44–46</td><td>32</td><td>21.5</td><td>37</td></tr>
          </tbody>
        </table>
      </div>

      <div class="pulsar-size-guide__tips">
        <p class="pulsar-size-guide__tip-heading">How to Measure</p>
        <ul class="pulsar-size-guide__tip-list">
          <li><strong>Chest</strong> — Measure around the fullest part of your chest, keeping the tape level.</li>
          <li><strong>Length</strong> — From the highest point of the shoulder to the bottom hem.</li>
          <li><strong>Sleeve</strong> — From the shoulder seam to the end of the cuff.</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
  .pulsar-size-guide-trigger {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }
  .pulsar-size-guide-trigger:hover { color: var(--pulsar-white); }

  .pulsar-size-guide {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pulsar-size-guide[hidden] { display: none; }

  .pulsar-size-guide__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .pulsar-size-guide__panel {
    position: relative;
    z-index: 1;
    background: var(--pulsar-dark2);
    border: 1px solid var(--pulsar-dark3);
    width: 90%;
    max-width: 640px;
    max-height: 85vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .pulsar-size-guide__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--pulsar-space-lg);
    border-bottom: 1px solid var(--pulsar-dark3);
    position: sticky;
    top: 0;
    background: var(--pulsar-dark2);
    z-index: 1;
  }
  .pulsar-size-guide__overline {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0;
    position: absolute;
    top: var(--pulsar-space-sm);
    left: var(--pulsar-space-lg);
  }
  .pulsar-size-guide__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 1.2rem 0 0;
  }
  .pulsar-size-guide__close {
    background: none;
    border: 1px solid var(--pulsar-dark3);
    color: var(--pulsar-gray2);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .pulsar-size-guide__close:hover { color: var(--pulsar-white); border-color: var(--pulsar-gray2); }

  .pulsar-size-guide__body {
    padding: var(--pulsar-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-lg);
  }

  .pulsar-size-guide__note {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--pulsar-gray2);
    margin: 0;
  }

  .pulsar-size-guide__table-wrap { overflow-x: auto; }
  .pulsar-size-guide__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 0.9rem;
  }
  .pulsar-size-guide__table th {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    padding: var(--pulsar-space-sm) var(--pulsar-space-md);
    border-bottom: 1px solid var(--pulsar-dark3);
    text-align: left;
    white-space: nowrap;
  }
  .pulsar-size-guide__table td {
    color: var(--pulsar-gray3);
    padding: var(--pulsar-space-sm) var(--pulsar-space-md);
    border-bottom: 1px solid var(--pulsar-dark3);
    white-space: nowrap;
  }
  .pulsar-size-guide__table tbody tr:hover td { color: var(--pulsar-white); }
  .pulsar-size-guide__table td:first-child {
    font-family: var(--font-secondary);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--pulsar-white);
  }

  .pulsar-size-guide__tip-heading {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0 0 var(--pulsar-space-sm);
  }
  .pulsar-size-guide__tip-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-sm);
  }
  .pulsar-size-guide__tip-list li {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--pulsar-gray2);
    line-height: 1.6;
    padding-left: 1rem;
    position: relative;
  }
  .pulsar-size-guide__tip-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--pulsar-gray1);
  }
  .pulsar-size-guide__tip-list li strong { color: var(--pulsar-white); font-weight: 500; }
</style>

<script>
  (function() {
    var trigger = document.querySelector('.pulsar-size-guide-trigger');
    var modal = document.getElementById('pulsar-size-guide-modal');
    if (!trigger || !modal) return;

    function openModal() {
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      trigger.setAttribute('aria-expanded', 'true');
      modal.querySelector('.pulsar-size-guide__close').focus();
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
      trigger.setAttribute('aria-expanded', 'false');
      trigger.focus();
    }

    trigger.addEventListener('click', openModal);

    modal.querySelectorAll('[data-pulsar-sg-close]').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });
  })();
</script>
