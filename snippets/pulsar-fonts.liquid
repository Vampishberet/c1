<style>
  /* ============================================
     Pulsar Self-Hosted Fonts
     Monument Extended + Neue Haas Display
     Loaded via Liquid to resolve CDN URLs
     ============================================ */

  @font-face {
    font-family: 'Monument Extended';
    src:
      url('{{ 'MonumentExtended-Regular.woff2' | asset_url }}') format('woff2'),
      url('{{ 'MonumentExtended-Regular.woff'  | asset_url }}') format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Neue Haas Display';
    src:
      url('{{ 'NeueHaasDisplayBold.woff2' | asset_url }}') format('woff2'),
      url('{{ 'NeueHaasDisplayBold.woff'  | asset_url }}') format('woff');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  /* Resolve font variables using the CDN-backed faces above */
  :root {
    --font-display:   'Monument Extended', 'Arial Narrow', sans-serif;
    --font-secondary: 'Bebas Neue', 'Arial Narrow', sans-serif;
    --font-accent:    'Neue Haas Display', 'Arial Black', sans-serif;
    --font-body:      'Inter', system-ui, -apple-system, sans-serif;
  }
</style>
