{%- comment -%}
  Usage: {% render 'pulsar-player-card', name: 'Chimp', game: 'Fortnite', role: 'Competitive', twitter: 'https://x.com/...' %}
{%- endcomment -%}
<div class="pulsar-player-card">
  <div class="pulsar-player-card__inner">
    <span class="pulsar-player-card__game">{{ game }}</span>
    <p class="pulsar-player-card__name">{{ name }}</p>
    {%- if role != blank -%}
      <span class="pulsar-player-card__role">{{ role }}</span>
    {%- endif -%}
    {%- if twitter != blank -%}
      <a
        href="{{ twitter }}"
        class="pulsar-player-card__social"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="{{ name }} on X"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</div>
