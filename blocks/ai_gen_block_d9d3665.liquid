{% doc %}
  @prompt
    Create a full-width Shopify homepage section with a black background and a responsive two-column layout. The left column should stack a small text element, a large heading element, a smaller supporting text element, and a button element with spacing between each. The right column should contain a vertical divider aligned to the left and a rich text container aligned to the right of the divider. The section should have generous padding, a centered max-width container, desktop-first layout that collapses to a single column on mobile, and no decorative corner elements or extra visual effects.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-hero-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
  }

  .ai-hero-left-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.element_spacing }}px;
  }

  .ai-hero-small-text-{{ ai_gen_id }} {
    color: {{ block.settings.small_text_color }};
    font-size: {{ block.settings.small_text_size }}px;
    margin: 0;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    margin: 0;
  }

  .ai-hero-supporting-text-{{ ai_gen_id }} {
    color: {{ block.settings.supporting_text_color }};
    font-size: {{ block.settings.supporting_text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-align: center;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    align-self: flex-start;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-right-column-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.divider_spacing }}px;
  }

  .ai-hero-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    flex-shrink: 0;
  }

  .ai-hero-richtext-{{ ai_gen_id }} {
    color: {{ block.settings.richtext_color }};
    font-size: {{ block.settings.richtext_size }}px;
    line-height: 1.6;
    flex-grow: 1;
  }

  .ai-hero-richtext-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-hero-richtext-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-divider-{{ ai_gen_id }} {
      width: 100%;
      height: {{ block.settings.divider_width }}px;
    }

    .ai-hero-right-column-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-grid-{{ ai_gen_id }}">
      <div class="ai-hero-left-column-{{ ai_gen_id }}">
        {% if block.settings.small_text != blank %}
          <div class="ai-hero-small-text-{{ ai_gen_id }}">
            {{ block.settings.small_text }}
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h1 class="ai-hero-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h1>
        {% endif %}

        {% if block.settings.supporting_text != blank %}
          <div class="ai-hero-supporting-text-{{ ai_gen_id }}">
            {{ block.settings.supporting_text }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-hero-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>

      <div class="ai-hero-right-column-{{ ai_gen_id }}">
        <div class="ai-hero-divider-{{ ai_gen_id }}"></div>
        <div class="ai-hero-richtext-{{ ai_gen_id }}">
          {{ block.settings.richtext_content }}
        </div>
      </div>
    </div>
  </div>
</div>

